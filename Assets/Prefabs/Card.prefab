  m_text: "<b>\u0411\u043E\u0440\u0430\u043D.</b>\n\u041A\u0438\u043D\u044C\u0442\u0435
    \u043A\u0443\u0431\u0438\u043A 2-\u0430 \u0440\u0430\u0437\u0430 \u043D\u0435
    \u043C\u0435\u043D\u0435\u0435 1-\u0433\u043E \u0438\u043B\u0438 1 \u0440\u0430\u0437
    \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 3-\u0445 \u0438 \u0437\u0430\u0431\u0435\u0440\u0438\u0442\u0435
    1-\u043A\u0430\u0440\u0442\u0443 \u0448\u043A\u0443\u0440\u0430 \u0431\u043E\u0440\u0430\u043D\u0430.
