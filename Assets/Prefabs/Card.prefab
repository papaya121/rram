    \u0434\u0440\u0430\u0442\u044C\u0441\u044F \u0441 \u0431\u0430\u043D\u0430\u043D\u043E\u043C,
    \u0432\u044B \u0432 \u043D\u0430\u0447\u0430\u043B\u0435 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0445\u043E\u0434\u0430 \u0441\u043D\u0438\u043C\u0430\u0435\u0442\u0435 \u043F\u043E
    1 \u043A\u0430\u0440\u0442\u0435 \u0441\u043E \u0441\u0432\u043E\u0435\u0433\u043E
    \u0441\u0442\u043E\u043B\u0431\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F."
