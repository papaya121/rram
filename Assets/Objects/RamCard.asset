  cardName: "<b>\u0411\u0430\u0440\u0430\u043d</b>\n\u041a\u0438\u043d\u044c\u0442\u0435 \u043a\u0443\u0431\u0438\u043a 2 \u0440\u0430\u0437\u0430. \u041d\u0443\u0436\u043d\u043e \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 1, \u043b\u0438\u0431\u043e \u043a\u0438\u043d\u044c\u0442\u0435 \u043a\u0443\u0431\u0438\u043a 1 \u0440\u0430\u0437 \u0438 \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u0435 \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 3.\n\u0412 \u0441\u043b\u0443\u0447\u0430\u0435 \u0443\u0441\u043f\u0435\u0445\u0430 \u0437\u0430\u0431\u0435\u0440\u0438\u0442\u0435 1 \u043a\u0430\u0440\u0442\u0443 \"\u0428\u043a\u0443\u0440\u0430 \u0431\u0430\u0440\u0430\u043d\u0430\". \u041a\u043e\u0433\u0434\u0430 \u0432\u044b \u043d\u0430\u0447\u0438\u043d\u0430\u0435\u0442\u0435 \u0434\u0440\u0430\u0442\u044c\u0441\u044f \u0441 \u0431\u0430\u0440\u0430\u043d\u043e\u043c, \u0432 \u043d\u0430\u0447\u0430\u043b\u0435 \u0441\u0432\u043e\u0435\u0433\u043e \u0445\u043e\u0434\u0430 \u0441\u043d\u0438\u043c\u0430\u0439\u0442\u0435 \u043f\u043e 1 \u043a\u0430\u0440\u0442\u0435 \u0441\u043e \u0441\u0432\u043e\u0435\u0433\u043e \u0441\u0442\u043e\u043b\u0431\u0430 \u0437\u0434\u043e\u0440\u043e\u0432\u044c\u044f."
