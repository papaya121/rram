  cardName: "<b>\u041a\u043b\u0443\u0431\u043e\u043a \u0441\u043f\u043b\u0435\u0442\u0435\u043d\u043d\u043e\u0439 \u043d\u0438\u0442\u0438 \u0438\u0437 \u0448\u0435\u0440\u0441\u0442\u0438 \u0431\u0430\u0440\u0430\u043d\u0430</b>\n\u0418\u043d\u0433\u0440\u0435\u0434\u0438\u0435\u043d\u0442 \u0434\u043b\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u043e\u0440\u0443\u0436\u0438\u044f, \u043b\u0435\u0433\u043a\u0438\u0445 \u0434\u043e\u0441\u043f\u0435\u0445\u043e\u0432, \u043f\u0440\u0435\u0434\u043c\u0435\u0442\u043e\u0432 \u0438 \u0442. \u0434.\n\u0421\u043c. \u0441\u043e\u0433\u043b\u0430\u0441\u043d\u043e \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f\u043c \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439 \u0438\u043b\u0438 \u0440\u0435\u0446\u0435\u043f\u0442\u043e\u0432."
