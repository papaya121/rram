  m_EditorClassIdentifier: Assembly-CSharp::RRaM.Core.Cards.RulebookCard
  cardName: "<b>\u0411\u0430\u0437\u043e\u0432\u044b\u0439 \u0440\u0435\u0446\u0435\u043f\u0442 \u043d\u0430 \u043a\u043e\u0432\u0435\u0440 \u0448\u0430\u043c\u0430\u043d\u0430</b>\n\u041d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u0435 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b: \u0448\u043a\u0443\u0440\u0430 \u043c\u0435\u0434\u0432\u0435\u0434\u044f - 1 \u043a\u0430\u0440\u0442\u0430; \u0441\u043f\u043b\u0435\u0442\u0435\u043d\u043d\u0430\u044f \u043d\u0438\u0442\u044c \u0438\u0437 \u0448\u043a\u0443\u0440\u044b \u0431\u0430\u0440\u0430\u043d\u0430 - 1 \u043a\u0430\u0440\u0442\u0430.\n\u0428\u0430\u043c\u0430\u043d \u043a\u0438\u0434\u0430\u0435\u0442 \u043a\u0443\u0431\u0438\u043a 1 \u0440\u0430\u0437. \u041d\u0443\u0436\u043d\u043e \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 3. \u0415\u0441\u043b\u0438 \u0437\u0430 2 \u043f\u043e\u043f\u044b\u0442\u043a\u0438 \u043d\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u043b\u043e\u0441\u044c, \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b \u0437\u0430\u043c\u0435\u0448\u0438\u0432\u0430\u044e\u0442\u0441\u044f \u043e\u0431\u0440\u0430\u0442\u043d\u043e \u0432 \u0441\u0432\u043e\u0438 \u043a\u043e\u043b\u043e\u0434\u044b, \u0430 \u0440\u0435\u0446\u0435\u043f\u0442 \u043e\u0441\u0442\u0430\u0435\u0442\u0441\u044f. \u0412 \u0441\u043b\u0443\u0447\u0430\u0435 \u0443\u0441\u043f\u0435\u0445\u0430 \u0448\u0430\u043c\u0430\u043d \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0440\u0435\u0446\u0435\u043f\u0442 \u0438 \u0437\u0430\u0431\u0438\u0440\u0430\u0435\u0442 \u0438\u0437\u0434\u0435\u043b\u0438\u0435."
