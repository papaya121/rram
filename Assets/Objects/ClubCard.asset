  m_Name: ClubCard
  m_EditorClassIdentifier: Assembly-CSharp::RRaM.Core.Cards.RulebookCard
  cardName: "<b>\u0414\u0443\u0431\u0438\u043d\u0430</b>\n\u041a\u043b\u0430\u0441\u0441: \u0432\u043e\u0438\u043d.\n\u0410\u0442\u0430\u043a\u0430 \u043f\u043e \u0432\u0440\u0430\u0433\u0443: \u0432 \u043d\u0430\u0447\u0430\u043b\u0435 \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u0441\u0432\u043e\u0435\u0433\u043e \u0445\u043e\u0434\u0430 \u0432\u0440\u0430\u0433 \u0441\u043d\u0438\u043c\u0430\u0435\u0442 10 \u043a\u0430\u0440\u0442 \u0441\u043e \u0441\u0442\u043e\u043b\u0431\u0430 \u0437\u0434\u043e\u0440\u043e\u0432\u044c\u044f \u0431\u0435\u0437 \u0443\u0447\u0435\u0442\u0430 \u0437\u0430\u0449\u0438\u0442\u044b \u0432\u0440\u0430\u0433\u0430.\n\u0410\u0442\u0430\u043a\u0430 \u043f\u043e \u0437\u0432\u0435\u0440\u044f\u043c: \u0435\u0441\u043b\u0438 \u0432 \u043f\u0435\u0440\u0432\u0443\u044e \u0441\u0432\u043e\u044e \u0430\u0442\u0430\u043a\u0443 \u0432\u044b \u043a\u0438\u043d\u0443\u043b\u0438 \u043a\u0443\u0431\u0438\u043a \u043d\u0430 4 \u0438\u043b\u0438 \u0432\u044b\u0448\u0435, \u0432\u044b \u0432\u044b\u0431\u0438\u0432\u0430\u0435\u0442\u0435 \u0437\u0432\u0435\u0440\u044f \u0441 \u043e\u0434\u043d\u043e\u0433\u043e \u0445\u043e\u0434\u0430 \u0430\u0442\u0430\u043a\u0438. \u0415\u0441\u043b\u0438 \u043d\u0435\u0442, \u0432\u044b \u0434\u0435\u0440\u0435\u0442\u0435\u0441\u044c \u0441\u043e \u0437\u0432\u0435\u0440\u0435\u043c \u0441\u043e\u0433\u043b\u0430\u0441\u043d\u043e \u0435\u0433\u043e \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044e."
