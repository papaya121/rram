  cardName: "<b>\u0428\u0435\u0440\u0441\u0442\u044c \u0431\u0430\u0440\u0430\u043d\u0430</b>\n\u041a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442 \u0434\u043b\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u043d\u0438\u0442\u0438.\n\u041a\u0438\u043d\u044c\u0442\u0435 \u043a\u0443\u0431\u0438\u043a 1 \u0440\u0430\u0437. \u041d\u0443\u0436\u043d\u043e \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 2, \u0438 \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442 \u043c\u043e\u0436\u043d\u043e \u043e\u0442\u043a\u0440\u044b\u0442\u044c, \u0447\u0442\u043e\u0431\u044b \u0437\u0430\u0431\u0440\u0430\u0442\u044c 1 \u043a\u0430\u0440\u0442\u0443 \"\u041a\u043b\u0443\u0431\u043e\u043a \u0441\u043f\u043b\u0435\u0442\u0435\u043d\u043d\u043e\u0439 \u043d\u0438\u0442\u0438\"."
