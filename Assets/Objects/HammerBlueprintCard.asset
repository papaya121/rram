  m_Name: HammerBlueprintCard
  m_EditorClassIdentifier: Assembly-CSharp::RRaM.Core.Cards.RulebookCard
  cardName: "<b>\u0411\u0430\u0437\u043e\u0432\u044b\u0439 \u0447\u0435\u0440\u0442\u0435\u0436 \u043d\u0430 \u043c\u043e\u043b\u043e\u0442\u043e\u043a</b>\n\u041a\u043b\u0430\u0441\u0441: \u043a\u0443\u0437\u043d\u0435\u0446.\n\u041d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u0435 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b: \u0441\u043c\u0435\u0448\u0430\u043d\u043d\u0430\u044f \u0436\u0435\u043b\u0435\u0437\u043d\u0430\u044f \u0440\u0443\u0434\u0430 - 1 \u043a\u0430\u0440\u0442\u0430.\n\u041a\u0443\u0437\u043d\u0435\u0446 \u043a\u0438\u0434\u0430\u0435\u0442 \u043a\u0443\u0431\u0438\u043a 2 \u0440\u0430\u0437\u0430. \u041d\u0443\u0436\u043d\u043e \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 2. \u0415\u0441\u043b\u0438 \u043a\u0443\u0437\u043d\u0435\u0446 \u043d\u0435 \u0441\u043c\u043e\u0436\u0435\u0442 \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043d\u0443\u0436\u043d\u043e\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0437\u0430 4 \u043f\u043e\u043f\u044b\u0442\u043a\u0438, \u043e\u043d \u043c\u043e\u0436\u0435\u0442 \u043f\u043e\u043f\u0440\u043e\u0431\u043e\u0432\u0430\u0442\u044c \u0435\u0449\u0435. \u0412 \u0441\u043b\u0443\u0447\u0430\u0435 \u0443\u0441\u043f\u0435\u0445\u0430 \u043a\u0443\u0437\u043d\u0435\u0446 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0447\u0435\u0440\u0442\u0435\u0436 \u0438 \u0437\u0430\u0431\u0438\u0440\u0430\u0435\u0442 \u043c\u043e\u043b\u043e\u0442\u043e\u043a."
