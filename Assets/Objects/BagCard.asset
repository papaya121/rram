  m_EditorClassIdentifier: Assembly-CSharp::RRaM.Core.Cards.RulebookCard
  cardName: "<b>\u041c\u0435\u0448\u043e\u043a</b>\n\u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043d\u043e\u0441\u0438\u0442\u044c \u043d\u0430 3 \u043a\u0430\u0440\u0442\u044b \u0431\u043e\u043b\u044c\u0448\u0435. \u0422\u0430\u043a\u0436\u0435 \u0432 \u044d\u0442\u043e\u043c \u043c\u0435\u0448\u043a\u0435 \u043c\u043e\u0436\u043d\u043e \u0443\u043b\u0443\u0447\u0448\u0430\u0442\u044c \u0436\u0435\u043b\u0435\u0437\u043d\u0443\u044e \u0440\u0443\u0434\u0443 \u0438 \u0437\u043e\u043b\u043e\u0442\u044b\u0435 \u0441\u0430\u043c\u043e\u0440\u043e\u0434\u043a\u0438.\n\u041d\u0430\u043f\u0440\u0438\u043c\u0435\u0440: \u0435\u0441\u043b\u0438 \u043f\u043e\u043c\u043e\u0449\u043d\u0438\u043a \u043a\u0443\u0437\u043d\u0435\u0446\u0430 \u0441\u043e\u0431\u0435\u0440\u0435\u0442 3 \u043a\u0430\u0440\u0442\u044b \u0441\u043c\u0435\u0448\u0430\u043d\u043d\u043e\u0439 \u0433\u0440\u044f\u0437\u043d\u043e\u0439 \u0436\u0435\u043b\u0435\u0437\u043d\u043e\u0439 \u0440\u0443\u0434\u044b, \u043f\u0443\u0441\u0442\u044c \u043a\u0438\u043d\u0435\u0442 \u043a\u0443\u0431\u0438\u043a 2 \u0440\u0430\u0437\u0430 \u0438 \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442 \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 2, \u0438\u043b\u0438 \u043a\u0438\u043d\u0435\u0442 \u043a\u0443\u0431\u0438\u043a 1 \u0440\u0430\u0437 \u0438 \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442 \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 5. \u0412 \u0441\u043b\u0443\u0447\u0430\u0435 \u0443\u0441\u043f\u0435\u0445\u0430 3 \u043a\u0430\u0440\u0442\u044b \u0441\u043c\u0435\u0448\u0430\u043d\u043d\u043e\u0439 \u0440\u0443\u0434\u044b \u0437\u0430\u043c\u0435\u0448\u0438\u0432\u0430\u044e\u0442\u0441\u044f \u043e\u0431\u0440\u0430\u0442\u043d\u043e \u0432 \u0441\u0432\u043e\u0438 \u043a\u043e\u043b\u043e\u0434\u044b, \u0430 \u043f\u043e\u043c\u043e\u0449\u043d\u0438\u043a \u043a\u0443\u0437\u043d\u0435\u0446\u0430 \u0431\u0435\u0440\u0435\u0442 1 \u043a\u0430\u0440\u0442\u0443 \u0436\u0435\u043b\u0435\u0437\u043d\u043e\u0439 \u0440\u0443\u0434\u044b \u0441\u0440\u0435\u0434\u043d\u0435\u0433\u043e \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430, \u0438 \u0442\u0430\u043a \u0434\u0430\u043b\u0435\u0435."
