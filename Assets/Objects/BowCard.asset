  m_Name: BowCard
  m_EditorClassIdentifier: Assembly-CSharp::RRaM.Core.Cards.RulebookCard
  cardName: "<b>\u041b\u0443\u043a</b>\n\u041a\u043b\u0430\u0441\u0441: \u043e\u0445\u043e\u0442\u043d\u0438\u043a.\n\u0410\u0442\u0430\u043a\u0430 \u043f\u043e \u0432\u0440\u0430\u0433\u0443: \u0432\u0440\u0430\u0433 \u0441\u043d\u0438\u043c\u0430\u0435\u0442 \u043f\u043e 5 \u043a\u0430\u0440\u0442 \u0432 \u043d\u0430\u0447\u0430\u043b\u0435 \u0441\u0432\u043e\u0435\u0433\u043e \u0445\u043e\u0434\u0430, \u0435\u0441\u043b\u0438 \u043d\u0430\u0445\u043e\u0434\u0438\u0442\u0441\u044f \u043d\u0430 \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0438 3 \u043a\u043b\u0435\u0442\u043e\u043a \u043e\u0442 \u0432\u0430\u0441. \u0415\u0441\u043b\u0438 \u0432\u0440\u0430\u0433 \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u043a \u0432\u0430\u043c \u0432\u043f\u043b\u043e\u0442\u043d\u0443\u044e, \u0432\u044b \u043d\u0435 \u043c\u043e\u0436\u0435\u0442\u0435 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u043b\u0443\u043a.\n\u0410\u0442\u0430\u043a\u0430 \u043f\u043e \u0437\u0432\u0435\u0440\u044f\u043c: \u043a\u0438\u043d\u044c\u0442\u0435 \u043a\u0443\u0431\u0438\u043a 2 \u0440\u0430\u0437\u0430 \u0438 \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u0435 \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 2, \u043b\u0438\u0431\u043e \u043a\u0438\u043d\u044c\u0442\u0435 \u043a\u0443\u0431\u0438\u043a 1 \u0440\u0430\u0437 \u0438 \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u0435 \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 5. \u0412 \u0441\u043b\u0443\u0447\u0430\u0435 \u0443\u0441\u043f\u0435\u0445\u0430 \u0443\u0431\u0435\u0439\u0442\u0435 \u0437\u0432\u0435\u0440\u044f: \u043c\u0435\u0434\u0432\u0435\u0434\u044f, \u0432\u043e\u043b\u043a\u0430, \u0441\u043e\u0432\u0443 \u0438\u043b\u0438 \u043a\u0430\u0431\u0430\u043d\u0430."
